# Health Insights - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# NOTE: This app stores API keys in localStorage for privacy
# =============================================================================
# Most API keys (Claude, Oura, Strava) are entered via the Settings page
# and stored in browser localStorage. This means:
# - Your data never leaves your browser
# - No server-side API calls with your credentials
# - Keys persist across sessions in YOUR browser only
#
# The only environment variables needed are for Strava OAuth redirect:

# Strava OAuth (optional - only if you want to pre-configure)
# Get these from https://www.strava.com/settings/api
# VITE_STRAVA_CLIENT_ID=your_client_id
# VITE_STRAVA_REDIRECT_URI=http://localhost:5173/import
